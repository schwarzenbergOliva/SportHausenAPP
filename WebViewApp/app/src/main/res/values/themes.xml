<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema base para todas las Activities Compose -->
    <style name="Theme.WebViewApp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>

    <!-- Tema del Splash usando la API moderna -->
    <style name="Theme.WebViewApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@android:drawable/sym_def_app_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.WebViewApp</item>
    </style>

</resources>
